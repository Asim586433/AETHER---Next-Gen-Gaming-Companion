{
  "name": "aether-gaming-companion",
  "version": "2.0.0",
  "description": "AETHER - Next-Gen Gaming Companion App with Auto-Recording, Cloud Storage, and Analytics",
  "main": "main.js",
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/aether-gaming-companion"
  },
  "keywords": [
    "valorant",
    "gaming",
    "electron",
    "recording",
    "overwolf",
    "gaming-app",
    "aether"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "release": "npm run build && npm run build:win",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^27.1.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.aether.companion",
    "productName": "AETHER",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "category": "public.app-category.games",
      "icon": "src/build/icon.icns"
    },
    "linux": {
      "category": "Game",
      "icon": "src/build/icon.png"
    }
  }
}
